{
  "expo": {
    "name": "Kojiro",
    "slug": "kojiro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "kojiro",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kojiro.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Kojiro utilise votre position pour trouver des matchs à proximité.",
        "NSCameraUsageDescription": "Kojiro utilise la caméra pour publier des photos et vidéos.",
        "NSPhotoLibraryUsageDescription": "Kojiro accède à vos photos pour votre profil et les highlights.",
        "NSMicrophoneUsageDescription": "Kojiro utilise le micro pour enregistrer des vidéos.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0B",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.kojiro.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0B"
        }
      ],
      "expo-image",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Kojiro utilise votre position pour trouver des matchs à proximité."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Kojiro accède à vos photos pour votre profil et les highlights.",
          "cameraPermission": "Kojiro utilise la caméra pour publier des photos et vidéos.",
          "microphonePermission": "Kojiro utilise le micro pour enregistrer des vidéos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#39FF14"
        }
      ],
      "expo-apple-authentication",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "82c43213-77bf-4227-9fb2-fce80d51c335"
      }
    }
  }
}
